---
import Layout from '../layouts/Layout.astro';

let posts: { title: string; link: string; date: string; description: string }[] = [];

try {
  const res = await fetch('https://devinlewtan.substack.com/feed');
  const xml = await res.text();

  const items = xml.match(/<item>([\s\S]*?)<\/item>/g) ?? [];
  posts = items.slice(0, 12).map((item) => {
    const title = item.match(/<title><!\[CDATA\[(.*?)\]\]><\/title>/)?.[1]
      ?? item.match(/<title>(.*?)<\/title>/)?.[1]
      ?? '';
    const link = item.match(/<link>(.*?)<\/link>/)?.[1] ?? '';
    const pubDate = item.match(/<pubDate>(.*?)<\/pubDate>/)?.[1] ?? '';
    const description = item.match(/<description><!\[CDATA\[(.*?)\]\]><\/description>/)?.[1]
      ?? item.match(/<description>(.*?)<\/description>/)?.[1]
      ?? '';
    const date = pubDate
      ? new Date(pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
      : '';
    const cleanDesc = description.replace(/<[^>]+>/g, '').trim().slice(0, 160);
    return { title, link, date, description: cleanDesc };
  });
} catch (_) {
  // If fetch fails at build time, show empty state
}
---

<Layout title="Writing">
  <div class="writing-header">
    <h1 class="page-title">Writing</h1>
    <a class="substack-link" href="https://devinlewtan.substack.com" target="_blank" rel="noopener">
      Read on Substack →
    </a>
  </div>

  {posts.length > 0 ? (
    <div class="writing-list">
      {posts.map((post) => (
        <a class="writing-post" href={post.link} target="_blank" rel="noopener">
          <div class="writing-post-meta">{post.date}</div>
          <div class="writing-post-title">{post.title}</div>
          {post.description && (
            <div class="writing-post-desc">{post.description}…</div>
          )}
        </a>
      ))}
    </div>
  ) : (
    <p class="placeholder">
      Read my writing on <a href="https://devinlewtan.substack.com" target="_blank" rel="noopener">Substack →</a>
    </p>
  )}
</Layout>

<style>
  .writing-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 40px;
  }

  .writing-header .page-title { margin-bottom: 0; }

  .substack-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--orange-text);
    text-decoration: none;
    border-bottom: 1.5px solid currentColor;
    padding-bottom: 1px;
  }

  .substack-link:hover { opacity: 0.7; }

  .writing-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .writing-post {
    display: block;
    padding: 24px 0;
    border-bottom: 1px solid rgba(0,0,0,0.1);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }

  .writing-post:first-child { border-top: 1px solid rgba(0,0,0,0.1); }

  .writing-post:hover { opacity: 0.65; }

  .writing-post-meta {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #999;
    margin-bottom: 6px;
  }

  .writing-post-title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 6px;
  }

  .writing-post-desc {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.5;
  }

  .placeholder a {
    color: var(--orange-text);
    font-weight: 600;
  }
</style>
