---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Play">
  <h1 class="page-title">Play</h1>

  <div class="play-grid">
    <div class="play-item">
      <img src="/images/play-illustration.jpg" alt="Interior illustration" />
      <div class="play-item-label">Illustration</div>
    </div>
    <div class="play-item">
      <img src="/images/play-phone-cases.jpg" alt="Hand-painted phone cases" />
      <div class="play-item-label">Hand-painted phone cases</div>
    </div>
  </div>
</Layout>
