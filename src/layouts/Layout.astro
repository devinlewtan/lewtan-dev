---
import '../styles/global.css';
interface Props {
  title?: string;
}
const { title = "Devin Lewtan" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Devin Lewtan — builder, artist, curator, lifelong learner. San Francisco, CA." />
  <title>{title === "Devin Lewtan" ? title : `${title} — Devin Lewtan`}</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  <script is:inline>
    (function(){
      var t = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
  <header>
    <a href="/" class="logo" aria-label="Devin Lewtan — home">
      <img src="/images/logo.png" alt="Devin Lewtan" class="logo-img" />
    </a>

    <div class="header-right">
      <div class="header-top-row">
      <div class="social-icons">
        <a href="https://instagram.com/devinlewtan" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a href="https://twitter.com/devinlewtan" target="_blank" rel="noopener" aria-label="Twitter / X">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://linkedin.com/in/devinlewtan" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
      </div>

      <!-- Dark mode toggle — fixed on desktop, inline on mobile -->
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
        <span class="toggle-track">
          <span class="toggle-half">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <circle cx="12" cy="12" r="3"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(0 12 12)"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(30 12 12)"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(60 12 12)"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(90 12 12)"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(120 12 12)"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(150 12 12)"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(180 12 12)"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(210 12 12)"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(240 12 12)"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(270 12 12)"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(300 12 12)"/>
              <line x1="12" y1="2.5" x2="12" y2="5.5" transform="rotate(330 12 12)"/>
            </svg>
          </span>
          <span class="toggle-half">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" stroke="none">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              <path d="M18.5 2 L19 3.5 L20.5 4 L19 4.5 L18.5 6 L18 4.5 L16.5 4 L18 3.5 Z"/>
            </svg>
          </span>
          <span class="toggle-dot"></span>
        </span>
      </button>
      </div>

      <div class="location">
        <span>📍 San Francisco, CA</span>
        <div class="location-history">
          <div class="loc-row"><span>Brooklyn, NY</span><span class="loc-years">2020–2026</span></div>
          <div class="loc-row"><span>New York, NY</span><span class="loc-years">2016–2020</span></div>
          <div class="loc-row"><span>Weston, MA</span><span class="loc-years">1998–2016</span></div>
        </div>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <script is:inline>
    document.getElementById('theme-toggle').addEventListener('click', function() {
      var html = document.documentElement;
      var isDark = html.getAttribute('data-theme') === 'dark';
      html.setAttribute('data-theme', isDark ? 'light' : 'dark');
      localStorage.setItem('theme', isDark ? 'light' : 'dark');
    });
  </script>

</body>
</html>

<style>
  /* ── Toggle halves — each takes 50% of track, icon centered within ── */
  .toggle-half {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    line-height: 0;
  }

  /* ── Location tooltip ── */
  .location {
    position: relative;
    font-size: 0.95rem;
    color: var(--fg);
    cursor: default;
    user-select: none;
    white-space: nowrap;
  }

  .location-history {
    position: absolute;
    right: 0;
    top: calc(100% + 10px);
    background: var(--fg);
    color: var(--bg);
    border-radius: 6px;
    padding: 10px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.22s ease, transform 0.22s ease;
    z-index: 200;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }

  .location-history::before {
    content: '';
    position: absolute;
    top: -6px;
    right: 14px;
    border: 6px solid transparent;
    border-top: none;
    border-bottom-color: var(--fg);
  }

  .location:hover .location-history {
    opacity: 1;
    transform: translateY(0);
  }

  .loc-row {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .loc-years { font-weight: 500; font-size: 0.78rem; }
  .loc-row:nth-child(1) .loc-years { color: #3ABCE4; }
  .loc-row:nth-child(2) .loc-years { color: #8FC95D; }
  .loc-row:nth-child(3) .loc-years { color: #E3924B; }
</style>
